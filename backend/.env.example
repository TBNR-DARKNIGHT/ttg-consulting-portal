# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=              # Service role key (server-side only, never expose to frontend)

# Clerk
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev
CLERK_SECRET_KEY=                    # Backend-only; fetches new-user profile data when JWT claims are incomplete
CLERK_AUDIENCE=                     # Optional in dev — set in staging/production for JWT aud verification

CLERK_WEBHOOK_SIGNING_SECRET=

# Google Sheets user reporting (backend-only)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_USERS_TAB=Users
GOOGLE_SHEETS_TTA_CODES_TAB=TTA Codes
# Paste the service-account credentials as single-line JSON.
GOOGLE_SERVICE_ACCOUNT_JSON=

# App
# When the SPA is on Vercel, set this to the exact site origin (e.g. https://your-project.vercel.app) so CORS allows the browser.
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_REGEX=
LOG_LEVEL=INFO
ENVIRONMENT=development             # development | staging | production
APP_VERSION=0.1.0

# Dedicated server-to-server secret for Zapier purchase fulfilment.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
ZAPIER_WEBHOOK_SECRET=

# Development authentication bypass (never enable in staging or production)
ALLOW_DEV_BEARER_AUTH=false
DEV_BEARER_TOKEN=

# EdXP-Users (authorization)
EDXP_AUTHZ_URL=
EDXP_ORG_ID=
EDXP_INTERNAL_JWT_SECRET=
EDXP_SERVICE_NAME=ttg-portal

# Mux Video
# Token ID from Mux dashboard → Settings → Access Tokens → Create Access Token (set permissions to "Read + Write")
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# Signing keys from Mux dashboard → Settings → Signing Keys)
MUX_SIGNING_KEY_ID=
MUX_SIGNING_PRIVATE_KEY=
