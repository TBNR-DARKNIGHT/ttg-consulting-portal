# Copy these names into the staging host's secret manager. Do not commit real values.

# Supabase staging project (backend-only service role)
SUPABASE_URL=https://STAGING_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=

# Clerk staging instance
CLERK_JWKS_URL=https://STAGING_CLERK_DOMAIN/.well-known/jwks.json
CLERK_ISSUER=https://STAGING_CLERK_DOMAIN
CLERK_AUDIENCE=
CLERK_SECRET_KEY=

# Exact staging SPA origin used by CORS
FRONTEND_URL=https://staging.example.com
FRONTEND_URL_REGEX=
ENVIRONMENT=staging
LOG_LEVEL=INFO
APP_VERSION=0.1.0

# Development authentication bypass must remain disabled in staging.
ALLOW_DEV_BEARER_AUTH=false
DEV_BEARER_TOKEN=

# Optional EdXP authorization service
EDXP_AUTHZ_URL=
EDXP_ORG_ID=
EDXP_INTERNAL_JWT_SECRET=
EDXP_SERVICE_NAME=ttg-portal

# Mux management API and paid-playback signing credentials
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_PRIVATE_KEY=
